{
  "name": "lila-tictac",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "typecheck": "tsc -b --noEmit",
    "backend:up": "docker-compose up -d",
    "backend:down": "docker-compose down",
    "backend:reset": "docker-compose down -v",
    "backend:restart": "docker-compose restart nakama",
    "backend:logs": "docker-compose logs -f nakama",
    "backend:ps": "docker-compose ps",
    "nakama:install": "npm --prefix nakama install",
    "nakama:build": "npm --prefix nakama run build",
    "nakama:console": "open http://localhost:7351",
    "dev:fresh": "./dev.sh",
    "start": "npm run nakama:build && docker-compose up -d && vite",
    "setup": "cp -n .env.example .env && npm install && npm run nakama:install"
  },
  "dependencies": {
    "@heroiclabs/nakama-js": "^2.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "typescript-eslint": "^8.57.2"
  }
}
